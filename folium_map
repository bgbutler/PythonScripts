# create a function to make legends for each metric

def add_legend(title, items, position='left', indent='10px'):
    
    legend_html = f"""
    <div style="
    position: fixed; bottom: 30px; {position}: {indent}; z-index: 10010;
    background: rgba(255,255,255,0.92);
    padding: 4px 6px; border: 1px solid #333; border-radius: 3px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.25);
    font-family: Arial, sans-serif; font-size: 10px; line-height: 1.2;
    pointer-events: none;
">
  <div style="font-weight:600; margin-bottom:2px;">{title}</div>
  { "".join([
      f"<div style='display:flex;align-items:center;margin:1px 0;'>"
      f"<span style='width:12px;height:8px;display:inline-block;"
      f"background:{col};border:1px solid #333;margin-right:4px;'></span>"
      f"<span>{val}</span></div>"
      for val, col in items.items()
    ]) }
</div>
"""
    return legend_html
   


