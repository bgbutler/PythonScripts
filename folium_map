## new categorical color mapping function

def categorical_color_map(values, palette: str):
    """
    Map each ordered category (from pd.cut) to a color from the given palette.
    Ensures lower bins get lighter colors and higher bins get darker colors.
    """
    cat = pd.Categorical(values)
    categories = list(cat.categories)  # preserves pd.cut bin order
    n = len(categories)
    if n == 0:
        return {}

    # Discrete colormap with n colors (YlOrRd: light -> dark)
    cmap = plt.get_cmap(palette, n)
    hex_colors = [mcolors.to_hex(cmap(i / (n - 1) if n > 1 else 0)) for i in range(n)]

    # ✅ The previously cut-off line:
    return {val: hex_colors[i] for i, val in enumerate(categories)}


