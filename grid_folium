# geopandas grid file to folium

# grid_out is your GeoDataFrame in a projected CRS (UTM).
# Folium expects WGS84 (lat/lon), so convert:
grid_wgs = grid_out.to_crs(epsg=4326)

# Center map on your exposure centroid
center = grid_wgs.geometry.union_all().centroid
m = folium.Map(location=[center.y, center.x], zoom_start=7, tiles="cartodbpositron")

# Choose what to color by
value_col = "tiv_sum"          # or "tiv_per_sqmi", "risk_count", etc.
vmin = float(grid_wgs[value_col].min())
vmax = float(grid_wgs[value_col].max())

# A simple linear colormap (you can switch to quantiles if you want)
colormap = cm.linear.YlOrRd_09.scale(vmin, vmax)
colormap.caption = value_col
colormap.add_to(m)


def style_fn(feature):
    val = feature["properties"].get(value_col, 0) or 0
    return {
        "fillColor": colormap(val),
        "color": "black",
        "weight": 0.2,
        "fillOpacity": 0.6,
    }

tooltip = folium.GeoJsonTooltip(
    fields=["grid_id", "risk_count", "tiv_sum", "tiv_per_sqmi", "risks_per_sqmi"],
    aliases=["Grid", "Risks", "TIV", "TIV / sq mi", "Risks / sq mi"],
    localize=True,
)




#### ALTERNATIVE MAP WITH CIRCLES
# 1️⃣ Compute centroids in projected CRS (meters)
grid_proj = grid_out.copy()  # still in UTM from earlier step

grid_proj["centroid"] = grid_proj.geometry.centroid

# Create a GeoDataFrame of centroids
centroids_proj = gpd.GeoDataFrame(
    grid_proj.drop(columns="geometry"),
    geometry=grid_proj["centroid"],
    crs=grid_proj.crs
)

# 2️⃣ Convert centroids to WGS84 for Folium
centroids_wgs = centroids_proj.to_crs(epsg=4326)

# 3️⃣ Extract lat/lon safely
centroids_wgs["lat"] = centroids_wgs.geometry.y
centroids_wgs["lon"] = centroids_wgs.geometry.x

for _, r in grid_wgs.iterrows():
    if r["risk_count"] == 0:
        continue
    radius = 2 + 8 * (np.log1p(r["tiv_sum"]) / (np.log1p(grid_wgs["tiv_sum"].max()) + 1e-9))
    folium.CircleMarker(
        location=[r["lat"], r["lon"]],
        radius=float(radius),
        fill=True,
        fill_opacity=0.6,
        opacity=0.6,
        tooltip=(
            f"grid_id={int(r['grid_id'])}<br>"
            f"risks={int(r['risk_count'])}<br>"
            f"TIV={r['tiv_sum']:,.0f}<br>"
            f"TIV/sqmi={r['tiv_per_sqmi']:,.0f}"
        ),
    ).add_to(m)

# m.save("grid_centroids_map.html")
m

folium.GeoJson(
    grid_wgs,
    name="Grid density",
    style_function=style_fn,
    tooltip=tooltip,
).add_to(m)

folium.LayerControl().add_to(m)

