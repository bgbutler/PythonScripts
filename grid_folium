m

# tips render non-zero grids
grid_wgs = grid_wgs[grid_wgs["risk_count"] > 0].copy()

# simplify geometry
grid_wgs["geometry"] = grid_wgs.geometry.simplify(tolerance=0.0005, preserve_topology=True)


