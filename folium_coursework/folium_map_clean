# Wrap it as a MacroElement so we can add it to the map
class FloatLegend(MacroElement):
    def __init__(self, html: str):
        super().__init__()
        self._name = "FloatLegend"
        # store the HTML fragment on the instance so the template can access it via `this.html`
        self.html = html
        # define a macro that accepts `this` and `kwargs` — branca will call this macro
        self._template = Template(
            """
            {% macro html(this, kwargs) %}
                {{ this.html | safe }}
            {% endmacro %}
            """
        )

