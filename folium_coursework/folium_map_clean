def fmt_int_commas(x):
    try:
        return f"{int(round(float(x))):,}"
    except Exception:
        return ""

def fmt_dollars_k(x):
    """Format as $X.XK or $X,XXXK (x is in dollars)."""
    try:
        x = float(x)
    except Exception:
        return ""
    xk = x / 1_000.0
    if abs(xk) >= 100:
        return f"${xk:,.0f}K"
    else:
        return f"${xk:,.1f}K"

def fmt_num(x, decimals=2):
    try:
        return f"{float(x):,.{decimals}f}"
    except Exception:
        return ""


