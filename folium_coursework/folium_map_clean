# ---- helper: format in K ----
def format_k_label(val):
    """Return a string like '1.2K' or '5,000K' (no currency symbol so legend matches tooltip style)."""
    val_k = val / 1_000.0
    # Choose formatting rules:
    if abs(val_k) >= 100:         # 100K+ -> no decimal, include thousands separators
        return f"${val_k:,.0f}K"
    else:                         # <100K -> one decimal point (e.g., 1.2K, 12.3K)
        return f"${val_k:,.1f}K"

