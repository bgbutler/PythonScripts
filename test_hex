def categorical_color_map(values, palette: str = "YlOrRd"):
    cat = pd.Categorical(values)
    categories = list(cat.categories)
    n = len(categories)
    if n == 0:
        return {}
    cmap = plt.get_cmap(palette, n)
    # produce hex colors from light -> dark
    hex_colors = [mcolors.to_hex(cmap(i / (n - 1) if n > 1 else 0)) for i in range(n)]
    return {val: hex_colors[i] for i, val in enumerate(categories)}

